generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Better Auth tables ---

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  accounts           Account[]
  expenses           Expense[]
  entriesCreated     Entry[]   @relation("EntryCreatedBy")
  transfersReceived  Entry[]   @relation("EntryTransferTo")
  memberships        GroupMember[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// --- App tables ---

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")

  members  GroupMember[]
  expenses Expense[]
  entries  Entry[]
  payments MonthPayment[]

  @@map("groups")
}

model GroupMember {
  id         String   @id @default(cuid())
  groupId    String   @map("group_id")
  group      Group    @relation(fields: [groupId], references: [id])
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  role       String   @default("member")
  countAsId  String?  @map("count_as_id")
  joinedAt   DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model Expense {
  id          String        @id @default(cuid())
  description String
  date        DateTime
  receiptUrl  String?       @map("receipt_url")
  createdById String        @map("created_by_id")
  createdBy   User          @relation(fields: [createdById], references: [id])
  groupId     String        @map("group_id")
  group       Group         @relation(fields: [groupId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  items       ExpenseItem[]

  @@index([date])
  @@index([createdById])
  @@index([groupId])
  @@map("expenses")
}

model ExpenseItem {
  id          String  @id @default(cuid())
  description String
  value       Decimal @db.Decimal(10, 2)
  expenseId   String  @map("expense_id")
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("expense_items")
}

model Entry {
  id          String      @id @default(cuid())
  type        String      @default("EXPENSE")
  description String
  date        DateTime
  receiptUrl  String?     @map("receipt_url")
  createdById String      @map("created_by_id")
  createdBy   User        @relation("EntryCreatedBy", fields: [createdById], references: [id])
  toUserId    String?     @map("to_user_id")
  toUser      User?       @relation("EntryTransferTo", fields: [toUserId], references: [id])
  groupId     String      @map("group_id")
  group       Group       @relation(fields: [groupId], references: [id])
  createdAt   DateTime    @default(now()) @map("created_at")
  items       EntryItem[]

  @@index([date])
  @@index([createdById])
  @@index([groupId])
  @@map("entries")
}

model EntryItem {
  id          String  @id @default(cuid())
  description String
  value       Decimal @db.Decimal(10, 2)
  entryId     String  @map("entry_id")
  entry       Entry   @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("entry_items")
}

model MonthPayment {
  id        String    @id @default(cuid())
  month     Int
  year      Int
  isPaid    Boolean   @default(false) @map("is_paid")
  paidAt    DateTime? @map("paid_at")
  paidBy    String?   @map("paid_by")
  groupId   String    @map("group_id")
  group     Group     @relation(fields: [groupId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([month, year, groupId])
  @@index([groupId])
  @@map("month_payments")
}
